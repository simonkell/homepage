---
import { getCollection } from "astro:content";
import Hero from "@/components/Hero.astro";
import Projects from "@/components/Projects.astro";
import Focus from "@/components/Focus.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/site";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order,
);
---

<BaseLayout title={site.title} description={site.description}>
  <main class="stack gap-30 lg:gap-48">
    <Hero
      id="about"
      eyebrow={site.hero.eyebrow}
      name={site.name}
      headline={site.hero.headline}
      paragraphs={site.hero.paragraphs}
      links={site.hero.links}
      roles={site.roles}
    />
    <section class="wrapper stack gap-30 lg:gap-48">
      <Projects projects={projects} />
      <Focus items={site.focus} />
    </section>
  </main>
</BaseLayout>
