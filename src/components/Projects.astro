---
import type { CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;

interface Props {
  projects: Project[];
}

const { projects } = Astro.props as Props;
const isExternal = (href?: string) => Boolean(href && /^https?:\/\//.test(href));
---

<section id="projects" class="scroll-mt-36 pt-20">
  <header class="section-header">
    <div>
      <p>Projekte</p>
      <h2>Ausgewählte Arbeiten</h2>
    </div>
    <p>
      Markdown-Dateien in <code>src/data/projects</code> steuern diese Liste.
    </p>
  </header>

  <div class="project-grid">
    {
      projects.map((project) => {
        const primaryHref = project.data.url ?? project.data.repo;
        return (
          <article class="project-card">
            <div class="project-card-top">
              <span>{project.data.status}</span>
              <span>{project.data.stack[0] ?? "Projekt"}</span>
            </div>
            <div class="project-card-body">
              <h3>
                {primaryHref ? (
                  <a
                    href={primaryHref}
                    target={isExternal(primaryHref) ? "_blank" : undefined}
                    rel={isExternal(primaryHref) ? "noreferrer" : undefined}
                  >
                    {project.data.title}
                  </a>
                ) : (
                  project.data.title
                )}
              </h3>
            <p>
              {project.data.description}
            </p>
            </div>
            <div class="stack-list">
              {project.data.stack.map((item) => (
                <span>
                  {item}
                </span>
              ))}
            </div>
            {(project.data.url || project.data.repo) && (
              <div class="project-links">
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target={isExternal(project.data.url) ? "_blank" : undefined}
                    rel={isExternal(project.data.url) ? "noreferrer" : undefined}
                  >
                    Demo ansehen -&gt;
                  </a>
                )}
                {project.data.repo && (
                  <a
                    href={project.data.repo}
                    target="_blank"
                    rel="noreferrer"
                  >
                    Code ansehen -&gt;
                  </a>
                )}
              </div>
            )}
          </article>
        );
      })
    }
  </div>
</section>

<style>
  section {
    scroll-margin-top: 6rem;
  }

  .section-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-header > p,
  .section-header div p {
    color: var(--accent-regular);
    font-family: var(--font-brand);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-header > p {
    max-width: 32ch;
    color: var(--gray-300);
    letter-spacing: 0;
    text-transform: none;
    font-family: var(--font-body);
    font-weight: 400;
  }

  h2 {
    margin-top: 0.4rem;
    font-size: var(--text-3xl);
  }

  .project-grid {
    display: grid;
    gap: 1.5rem;
  }

  .project-card {
    display: grid;
    min-height: 22rem;
    gap: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    background:
      radial-gradient(circle at 20% 15%, var(--accent-overlay), transparent 30%),
      var(--gradient-subtle);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--theme-transition),
      box-shadow var(--theme-transition);
  }

  .project-card:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--shadow-md);
  }

  .project-card-top,
  .stack-list,
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card-top {
    justify-content: space-between;
    align-self: start;
  }

  .project-card-top span,
  .stack-list span {
    padding: 0.35rem 0.7rem;
    border-radius: 999rem;
    color: var(--gray-300);
    background: color-mix(in srgb, var(--gray-999) 72%, transparent);
    border: 1px solid var(--gray-800);
    font-size: var(--text-sm);
  }

  .project-card-body {
    align-self: end;
  }

  h3 {
    margin-bottom: 1rem;
    font-size: var(--text-2xl);
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  .project-card-body p {
    color: var(--gray-300);
  }

  .project-links {
    align-self: end;
  }

  .project-links a {
    color: var(--accent-regular);
    font-family: var(--font-brand);
    font-weight: 700;
    text-decoration: none;
  }

  @media (min-width: 50em) {
    .section-header {
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 3rem;
      margin-bottom: 4rem;
    }

    .section-header > p {
      text-align: right;
    }

    .project-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      padding-bottom: 7.5rem;
    }

    .project-card {
      min-height: 28rem;
      border-radius: 2.25rem;
      padding: 2rem;
    }

    .project-card:nth-child(odd) {
      transform: translateY(7.5rem);
    }

    .project-card:nth-child(odd):hover {
      transform: translateY(7.25rem);
    }
  }
</style>
