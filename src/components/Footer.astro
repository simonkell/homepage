---
type LinkItem = {
  label: string;
  href: string;
};

interface Props {
  status: string;
  links: LinkItem[];
}

const { status, links } = Astro.props as Props;
---

<footer id="contact">
  <div class="status">
    <span aria-hidden="true"></span>
    <p>{status}</p>
  </div>
  <div class="socials">
    {
      links.map((link) => (
        <a href={link.href}>
          {link.label}
        </a>
      ))
    }
  </div>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: auto;
    padding: 5rem 1.5rem 3rem;
    border-top: 1px solid var(--gray-800);
    color: var(--gray-400);
    font-size: var(--text-sm);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .status span {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999rem;
    background: var(--accent-regular);
  }

  .status p {
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  a {
    color: var(--gray-300);
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  a:hover,
  a:focus {
    text-decoration-color: currentColor;
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 5rem;
    }
  }
</style>
