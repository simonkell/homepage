---
type NavItem = {
  href: string;
  label: string;
};

interface Props {
  nav: NavItem[];
}

const { nav } = Astro.props as Props;
---

<header class="fixed left-1/2 top-0 z-40 flex w-full max-w-2xl -translate-x-1/2 items-center justify-center bg-background/90 px-5 py-8 backdrop-blur md:py-10">
  <nav aria-label="Hauptnavigation" class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm">
    {
      nav.map((item) => (
        <a
          class="text-muted-foreground transition-colors duration-200 hover:text-foreground"
          href={item.href}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="pointer-events-none absolute -bottom-12 left-0 h-16 w-full bg-linear-to-b from-background via-background/80 to-background/0"></div>
</header>
