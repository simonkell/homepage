---
type NavItem = {
  href: string;
  label: string;
};

interface Props {
  name: string;
  nav: NavItem[];
}

const { name, nav } = Astro.props as Props;
---

<header class="site-header">
  <a class="site-title" href="/" aria-label={`${name} Startseite`}>
    <span aria-hidden="true" class="site-mark">SK</span>
    {name}
  </a>
  <nav aria-label="Hauptnavigation" class="nav-items">
    {
      nav.map((item) => (
        <a href={item.href}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem;
    font-family: var(--font-brand);
    font-weight: 700;
  }

  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--gray-0);
    text-decoration: none;
  }

  .site-mark {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999rem;
    background: var(--gradient-accent);
    color: var(--accent-text-over);
    font-size: 0.8rem;
    box-shadow: var(--shadow-md);
  }

  .nav-items {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0.45rem;
    border-radius: 999rem;
    background: color-mix(in srgb, var(--gray-999) 78%, transparent);
    border: 1px solid var(--gray-800);
    box-shadow: var(--shadow-sm);
  }

  .nav-items a {
    padding: 0.55rem 0.9rem;
    border-radius: 999rem;
    color: var(--gray-300);
    text-decoration: none;
    font-size: var(--text-sm);
    transition:
      color var(--theme-transition),
      background-color var(--theme-transition);
  }

  .nav-items a:hover,
  .nav-items a:focus {
    color: var(--gray-0);
    background-color: var(--accent-subtle-overlay);
  }

  @media (max-width: 42em) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav-items {
      justify-content: flex-start;
      border-radius: 1.5rem;
    }
  }

  @media (min-width: 50em) {
    .site-header {
      padding: 2.5rem 5rem;
    }
  }
</style>
